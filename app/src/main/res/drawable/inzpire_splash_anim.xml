<?xml version="1.0" encoding="utf-8"?>
<!-- inzpire splash - petal-by-petal reveal, then i + dot -->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/inzpire_splash_logo">

    <target android:name="w0">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="fillAlpha"
                android:startOffset="0" android:duration="220"
