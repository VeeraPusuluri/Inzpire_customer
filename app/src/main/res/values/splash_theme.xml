<?xml version="1.0" encoding="utf-8"?>
<!-- Inzpire Customer: Android 12+ SplashScreen. Requires androidx.core:core-splashscreen -->
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/inzpire_splash_anim</item>
        <item name="windowSplashScreenAnimationDuration">1435</item>
        <item name="postSplashScreenTheme">@style/Theme.InzpireCustomer</item>
    </style>
</resources>
